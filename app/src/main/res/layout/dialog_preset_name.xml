<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/aurora_card"
    android:layout_margin="16dp"
    android:outlineAmbientShadowColor="@color/aurora_glow_blue"
    android:outlineSpotShadowColor="@color/aurora_glow_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/card_glow_bg">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE PRESET"
            android:textColor="@color/aurora_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/dialogSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name this configuration for quick access"
            android:textColor="@color/aurora_text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/presetNameInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Preset name"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/aurora_accent"
            app:hintTextColor="@color/aurora_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/presetNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/aurora_text"
                android:textColorHint="@color/aurora_text_secondary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/presetCustomImageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Use custom image"
            android:textAllCaps="false"
            android:textColor="@color/aurora_text"
            android:visibility="gone"
            app:icon="@drawable/ic_gallery"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/aurora_text"
            app:strokeColor="@color/aurora_accent"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogCancelButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/button_secondary_pill"
                android:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/aurora_text"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogConfirmButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/button_primary_pill"
                android:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
