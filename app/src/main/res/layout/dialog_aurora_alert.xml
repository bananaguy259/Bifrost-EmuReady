<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/aurora_card"
    android:layout_margin="16dp"
    android:outlineAmbientShadowColor="@color/aurora_glow_green"
    android:outlineSpotShadowColor="@color/aurora_glow_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/card_glow_bg">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/aurora_alert_title_placeholder"
            android:textColor="@color/aurora_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/dialogSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/aurora_alert_subtitle_placeholder"
            android:textColor="@color/aurora_text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/dialogBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/aurora_alert_body_placeholder"
            android:textColor="@color/aurora_text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogCancelButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/button_secondary_pill"
                android:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/aurora_text"
                android:textSize="14sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogConfirmButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/button_primary_pill"
                android:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Confirm"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
