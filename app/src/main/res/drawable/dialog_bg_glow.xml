<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#12182B" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#1A22C55E"
                android:centerColor="#1A3B82F6"
                android:endColor="#1A22D3EE"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>